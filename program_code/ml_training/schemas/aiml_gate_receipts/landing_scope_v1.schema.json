{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "landing_scope_v1.schema.json",
  "title": "AIML landing scope identity",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "landing_scope_id",
    "scope_kind",
    "platform_scope",
    "policy_surface_id",
    "decision_cells",
    "evidence_environments",
    "promotion_edges"
  ],
  "properties": {
    "schema_version": {"const": "landing_scope_v1"},
    "landing_scope_id": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "scope_kind": {"const": "INSTANCE"},
    "platform_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["venue", "instrument_class", "strategy_family"],
      "properties": {
        "venue": {"type": "string", "minLength": 1},
        "instrument_class": {"type": "string", "minLength": 1},
        "strategy_family": {"type": "string", "minLength": 1}
      }
    },
    "policy_surface_id": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "decision_cells": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["symbol", "side", "horizon", "regime"],
        "properties": {
          "symbol": {"type": "string", "minLength": 1},
          "side": {"type": "string", "minLength": 1},
          "horizon": {"type": "string", "minLength": 1},
          "regime": {"type": "string", "minLength": 1}
        }
      }
    },
    "evidence_environments": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["environment_id", "mode", "account_or_simulator", "fee_schedule", "execution_policy"],
        "properties": {
          "environment_id": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
          "mode": {"type": "string", "minLength": 1},
          "account_or_simulator": {"type": "string", "minLength": 1},
          "fee_schedule": {"type": "string", "minLength": 1},
          "execution_policy": {"type": "string", "minLength": 1}
        }
      }
    },
    "promotion_edges": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["from_environment_id", "to_environment_id", "authority_receipt_digest"],
        "properties": {
          "from_environment_id": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
          "to_environment_id": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
          "authority_receipt_digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}
        }
      }
    }
  }
}

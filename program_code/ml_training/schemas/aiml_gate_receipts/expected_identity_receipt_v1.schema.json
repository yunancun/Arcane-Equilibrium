{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arcane-equilibrium.local/schemas/expected_identity_receipt_v1.schema.json",
  "title": "expected_identity_receipt_v1",
  "description": "Canonical self-hashed receipt emitted by sealed_build_adapter_v1 for AIML LR2 (S2.3). It BINDS (projects) the S1.3 least-privilege identity/ACL matrix onto the S2.3 sealed build: per-component host UID / dedicated PG role / local-only auth method / private socket-dir mode / protected secret loader, all non-root with no OCI socket and no DBus authority. It does NOT re-derive the identity topology; expected_component_identities is a projection of S1.3's canonical_identity_acl_contract, negative_acl_binding projects S1.3's OVER_GRANT_KINDS (count >= 10, all_rejected), and rollback_binding projects S1.3's change kinds. Every production_provisioned.* is const false (provisioning is S2.4) and every running_attested.* is const false (running attestation is S2.5/LR6), so observation_owner is const S2.5_LR6. The delegated Python validator independently re-projects S1.3 and rejects any component mislabel, any oci_socket_access/dbus_authority true, count < 10, or a broken negative/rollback binding (schema if/then only guards PASS => failure_reason null). Evidence-authenticity contract (CLAUDE.md): a self-hashed receipt authenticates integrity only; the real provisioning and running identity are S2.4/S2.5.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "adapter_id",
    "status",
    "caller",
    "platform",
    "selected_runtime_kind",
    "sealed_build_digest",
    "runtime_content_digest",
    "identity_acl_contract_digest",
    "expected_component_identities",
    "least_privilege_assertions",
    "negative_acl_binding",
    "secret_loading_binding",
    "rollback_binding",
    "production_provisioned",
    "running_attested",
    "observation_owner",
    "source_sha256",
    "schema_sha256",
    "secret_scan",
    "observation_time",
    "expires_at",
    "ttl_seconds",
    "failure_reason",
    "self_digest"
  ],
  "properties": {
    "schema_version": {"const": "expected_identity_receipt_v1"},
    "adapter_id": {"const": "sealed_build_adapter_v1"},
    "status": {"enum": ["PASS", "FAIL"]},
    "caller": {"type": "string", "minLength": 1},
    "platform": {
      "type": "object",
      "additionalProperties": false,
      "required": ["os", "arch", "python_version", "target_platform"],
      "properties": {
        "os": {"enum": ["darwin", "linux"]},
        "arch": {"type": "string", "minLength": 1},
        "python_version": {"type": "string", "minLength": 1},
        "target_platform": {"type": "string", "minLength": 1}
      }
    },
    "selected_runtime_kind": {"const": "content_addressed_fixed_path"},
    "sealed_build_digest": {"$ref": "#/$defs/digest"},
    "runtime_content_digest": {"$ref": "#/$defs/digest"},
    "identity_acl_contract_digest": {"$ref": "#/$defs/digest"},
    "expected_component_identities": {
      "type": "array",
      "minItems": 5,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "component",
          "uid_label",
          "pg_role",
          "privilege_class",
          "auth_method",
          "socket_dir_mode",
          "protected_secret_loader",
          "oci_socket_access",
          "dbus_authority",
          "non_root"
        ],
        "properties": {
          "component": {"enum": ["engine_scanner", "controller", "fit_evaluation", "serving", "deleter"]},
          "uid_label": {"type": "string", "minLength": 1},
          "pg_role": {"type": "string", "minLength": 1},
          "privilege_class": {
            "enum": [
              "observer_read_only", "scanner_capture_writer", "queue_writer",
              "fit_evaluation_writer", "serving_read_only", "retention_deleter"
            ]
          },
          "auth_method": {"enum": ["pg_hba_ident_local", "pg_hba_scram_local", "authenticated_loopback"]},
          "socket_dir_mode": {"type": "string", "pattern": "^0[0-7]{3}$"},
          "protected_secret_loader": {"type": "string", "minLength": 1},
          "oci_socket_access": {"const": false},
          "dbus_authority": {"const": false},
          "non_root": {"const": true}
        }
      }
    },
    "least_privilege_assertions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["no_oci_socket", "no_dbus_authority", "host_systemd_owns_lifecycle", "non_root_all"],
      "properties": {
        "no_oci_socket": {"const": true},
        "no_dbus_authority": {"const": true},
        "host_systemd_owns_lifecycle": {"const": true},
        "non_root_all": {"const": true}
      }
    },
    "negative_acl_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["s1_3_negatives_digest", "count", "all_rejected"],
      "properties": {
        "s1_3_negatives_digest": {"$ref": "#/$defs/digest"},
        "count": {"type": "integer", "minimum": 10},
        "all_rejected": {"const": true}
      }
    },
    "secret_loading_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["no_plaintext_ingress", "plaintext_ingress"],
      "properties": {
        "no_plaintext_ingress": {"const": true},
        "plaintext_ingress": {"const": false}
      }
    },
    "rollback_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rollback_present", "change_kinds", "rollback_digest"],
      "properties": {
        "rollback_present": {"const": true},
        "change_kinds": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "rollback_digest": {"$ref": "#/$defs/digest"}
      }
    },
    "production_provisioned": {
      "type": "object",
      "additionalProperties": false,
      "required": ["uid", "pg_role", "hba", "socket", "credential"],
      "properties": {
        "uid": {"const": false},
        "pg_role": {"const": false},
        "hba": {"const": false},
        "socket": {"const": false},
        "credential": {"const": false}
      }
    },
    "running_attested": {
      "type": "object",
      "additionalProperties": false,
      "required": ["unit", "pid_cgroup", "mount", "network", "pg_identity"],
      "properties": {
        "unit": {"const": false},
        "pid_cgroup": {"const": false},
        "mount": {"const": false},
        "network": {"const": false},
        "pg_identity": {"const": false}
      }
    },
    "observation_owner": {"const": "S2.5_LR6"},
    "source_sha256": {"$ref": "#/$defs/digest"},
    "schema_sha256": {"$ref": "#/$defs/digest"},
    "secret_scan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["patterns_checked", "leaked"],
      "properties": {
        "patterns_checked": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "leaked": {"const": false}
      }
    },
    "observation_time": {"$ref": "#/$defs/timestamp"},
    "expires_at": {"$ref": "#/$defs/timestamp"},
    "ttl_seconds": {"type": "integer", "minimum": 1, "maximum": 3600},
    "failure_reason": {"anyOf": [{"type": "string", "minLength": 1}, {"type": "null"}]},
    "self_digest": {"$ref": "#/$defs/digest"}
  },
  "allOf": [
    {
      "if": {"properties": {"status": {"const": "PASS"}}},
      "then": {
        "properties": {
          "failure_reason": {"type": "null"}
        }
      },
      "else": {
        "properties": {
          "failure_reason": {"type": "string", "minLength": 1}
        }
      }
    }
  ],
  "$defs": {
    "digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "timestamp": {"type": "string", "format": "date-time"}
  }
}

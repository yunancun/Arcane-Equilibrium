{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "session_attempt_v1.schema.json",
  "title": "Durable AIML session attempt admission and lease",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "attempt_id", "session_id", "scope_ref", "cohort_epoch", "attempt", "attempt_key", "attempt_phase", "status", "owner", "lease", "source", "path_manifest", "work_package", "dependency_generations", "bootstrap_admission", "native_admission", "dag_nodes", "semantic_rechecks", "ci_classifier", "effect_classification_digest", "created_at", "self_digest"],
  "properties": {
    "schema_version": {"const": "session_attempt_v1"},
    "attempt_id": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "session_id": {"type": "string", "pattern": "^S[0-9]+(?:\\.[0-9A-Z]+)*$"},
    "scope_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "landing_scope_id"],
      "properties": {
        "kind": {"enum": ["PROGRAM", "LANDING_SCOPE"]},
        "landing_scope_id": {"type": ["string", "null"], "pattern": "^sha256:[0-9a-f]{64}$"}
      }
    },
    "cohort_epoch": {"type": "string", "minLength": 1},
    "attempt": {"type": "integer", "minimum": 1},
    "attempt_key": {
      "type": "object",
      "additionalProperties": false,
      "required": ["session_id", "scope_ref", "cohort_epoch", "attempt"],
      "properties": {
        "session_id": {"type": "string", "minLength": 1},
        "scope_ref": {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "landing_scope_id"],
          "properties": {
            "kind": {"enum": ["PROGRAM", "LANDING_SCOPE"]},
            "landing_scope_id": {"type": ["string", "null"], "pattern": "^sha256:[0-9a-f]{64}$"}
          }
        },
        "cohort_epoch": {"type": "string", "minLength": 1},
        "attempt": {"type": "integer", "minimum": 1}
      }
    },
    "attempt_phase": {"enum": ["SOURCE_BUILD", "POST_MERGE_FINALIZATION"]},
    "status": {"enum": ["CLAIMED", "IN_PROGRESS", "BLOCKED_STALE_EVIDENCE", "RECOVERY_REQUIRED", "MERGED", "FINALIZED"]},
    "owner": {"type": "string", "minLength": 1},
    "lease": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lease_id", "epoch", "acquired_at", "heartbeat_at", "expires_at"],
      "properties": {
        "lease_id": {"type": "string", "minLength": 1},
        "epoch": {"type": "integer", "minimum": 1},
        "acquired_at": {"type": "string", "format": "date-time"},
        "heartbeat_at": {"type": "string", "format": "date-time"},
        "expires_at": {"type": "string", "format": "date-time"}
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["branch", "worktree", "baseline_head", "checkpoint_head"],
      "properties": {
        "branch": {"type": "string", "minLength": 1},
        "worktree": {"type": "string", "pattern": "^/"},
        "baseline_head": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
        "checkpoint_head": {"type": "string", "pattern": "^[0-9a-f]{40}$"}
      }
    },
    "path_manifest": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+"}},
    "work_package": {
      "type": "object",
      "additionalProperties": false,
      "required": ["work_package_id", "phase", "side_effect_class", "runtime_claim", "owned_path_manifest", "direct_interfaces"],
      "properties": {
        "work_package_id": {"const": "AIML-S0.3-GOVERNANCE-ADOPTION"},
        "phase": {"enum": ["SOURCE_BUILD", "POST_MERGE_FINALIZATION"]},
        "side_effect_class": {"enum": ["repo_write", "none"]},
        "runtime_claim": {"const": false},
        "owned_path_manifest": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "direct_interfaces": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
      }
    },
    "dependency_generations": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["session_id", "schema_version", "receipt_digest"],
        "properties": {
          "session_id": {"type": "string", "minLength": 1},
          "schema_version": {"type": "string", "minLength": 1},
          "receipt_digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}
        }
      }
    },
    "bootstrap_admission": {
      "type": "object",
      "additionalProperties": false,
      "required": ["task_id", "task_contract_digest", "dag_digest", "context_artifact_digest", "baseline_head", "writer_lease_id"],
      "properties": {
        "task_id": {"const": "AIML-S0-3-GOVERNANCE-V1"},
        "task_contract_digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
        "dag_digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
        "context_artifact_digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
        "baseline_head": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
        "writer_lease_id": {"type": "string", "minLength": 1}
      }
    },
    "native_admission": {
      "type": "object",
      "additionalProperties": false,
      "required": ["node_id", "role", "native_agent", "node_class", "permission"],
      "properties": {
        "node_id": {"type": "string", "minLength": 1},
        "role": {"type": "string", "minLength": 1},
        "native_agent": {"type": "string", "minLength": 1},
        "node_class": {"enum": ["work", "verification", "controller", "validator"]},
        "permission": {"type": "string", "minLength": 1}
      }
    },
    "dag_nodes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["node_id", "node_class", "permission", "requires", "writer_paths"],
        "properties": {
          "node_id": {"type": "string", "minLength": 1},
          "node_class": {"enum": ["work", "verification", "controller", "validator", "effect_adapter", "join"]},
          "permission": {"type": "string", "minLength": 1},
          "requires": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
          "writer_paths": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
        }
      }
    },
    "semantic_rechecks": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "ci_classifier": {
      "type": "object",
      "additionalProperties": false,
      "required": ["classifier_digest", "selected_workflows", "invocation_history", "failure_fingerprints"],
      "properties": {
        "classifier_digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
        "selected_workflows": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "invocation_history": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "failure_fingerprints": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}}
      }
    },
    "effect_classification_digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "created_at": {"type": "string", "format": "date-time"},
    "self_digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}
  }
}

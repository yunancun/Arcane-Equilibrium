{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arcane-equilibrium.local/schemas/runtime_candidate_receipt_v1.schema.json",
  "title": "runtime_candidate_receipt_v1",
  "description": "Canonical self-hashed receipt emitted by runtime_candidate_spike_v1 for ONE learning-runtime candidate (exact-image-ID OCI, or content-addressed fixed-path) evaluated on the OFFLINE-only seams. S1.4 (LR0C) is disposable-offline: target_host is rejected fail-closed, every runtime-only seam is DEFERRED_S1_6, and S1.4 structurally cannot select a runtime (that is S1.6).",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "harness_id",
    "status",
    "caller",
    "platform",
    "candidate",
    "target_class",
    "evidence_class",
    "dependency_closure",
    "native_library_inventory",
    "isolation_mode",
    "sealed_input",
    "immutability",
    "artifact_persistence",
    "rollback",
    "oci_build",
    "seams",
    "source_sha256",
    "schema_sha256",
    "secret_scan",
    "observation_time",
    "expires_at",
    "ttl_seconds",
    "failure_reason",
    "self_digest"
  ],
  "properties": {
    "schema_version": {"const": "runtime_candidate_receipt_v1"},
    "harness_id": {"const": "runtime_candidate_spike_v1"},
    "status": {"enum": ["PASS", "FAIL"]},
    "caller": {"type": "string", "minLength": 1},
    "platform": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "os",
        "arch",
        "python_version",
        "container_runtime",
        "container_runtime_available",
        "buildx_available"
      ],
      "properties": {
        "os": {"enum": ["darwin", "linux"]},
        "arch": {"type": "string", "minLength": 1},
        "python_version": {"type": "string", "minLength": 1},
        "container_runtime": {"anyOf": [{"type": "string", "minLength": 1}, {"type": "null"}]},
        "container_runtime_available": {"type": "boolean"},
        "buildx_available": {"type": "boolean"}
      }
    },
    "candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind"],
      "properties": {
        "id": {"enum": ["exact_image_id_oci", "content_addressed_fixed_path"]},
        "kind": {"type": "string", "minLength": 1}
      }
    },
    "target_class": {"enum": ["disposable_offline", "target_host"]},
    "evidence_class": {"enum": ["LOCAL_REPRODUCIBLE", "STRUCTURAL_ONLY"]},
    "dependency_closure": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lock_tool",
        "lock_input_ref",
        "closure_hash",
        "hashed_input_count",
        "real_ml_closure_resolved"
      ],
      "properties": {
        "lock_tool": {"type": "string", "minLength": 1},
        "lock_input_ref": {"type": "string", "minLength": 1},
        "closure_hash": {"$ref": "#/$defs/digest"},
        "hashed_input_count": {"type": "integer", "minimum": 0},
        "real_ml_closure_resolved": {"const": false}
      }
    },
    "native_library_inventory": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "origin", "sha256", "load_verified_on_target"],
        "properties": {
          "name": {"type": "string", "minLength": 1},
          "origin": {"type": "string", "minLength": 1},
          "sha256": {"$ref": "#/$defs/digest"},
          "load_verified_on_target": {"const": false}
        }
      }
    },
    "isolation_mode": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "python_isolated_mode",
        "ignores_ambient_env",
        "system_python_fallback_possible",
        "launch_interpreter",
        "evidence_class"
      ],
      "properties": {
        "python_isolated_mode": {"type": "boolean"},
        "ignores_ambient_env": {"type": "boolean"},
        "system_python_fallback_possible": {"type": "boolean"},
        "launch_interpreter": {"enum": ["absolute_pinned", "path_lookup"]},
        "evidence_class": {"enum": ["LOCAL_REPRODUCIBLE", "STRUCTURAL_ONLY"]}
      }
    },
    "sealed_input": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sealed_input_digest", "inputs", "reproducible_output_verified"],
      "properties": {
        "sealed_input_digest": {"$ref": "#/$defs/digest"},
        "inputs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["ref", "sha256"],
            "properties": {
              "ref": {"type": "string", "minLength": 1},
              "sha256": {"$ref": "#/$defs/digest"}
            }
          }
        },
        "reproducible_output_verified": {"const": false}
      }
    },
    "immutability": {
      "type": "object",
      "additionalProperties": false,
      "required": ["identity_kind", "mutable_tag_or_alias", "relocatable_renamed_venv"],
      "properties": {
        "identity_kind": {"enum": ["exact_image_id", "content_addressed_path"]},
        "mutable_tag_or_alias": {"const": false},
        "relocatable_renamed_venv": {"const": false}
      }
    },
    "artifact_persistence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["model", "inside_immutable_image_or_bundle"],
      "properties": {
        "model": {"enum": ["external_volume", "fixed_data_path"]},
        "inside_immutable_image_or_bundle": {"const": false}
      }
    },
    "rollback": {
      "type": "object",
      "additionalProperties": false,
      "required": ["shape", "prior_identity_pinned", "mutable_current_symlink"],
      "properties": {
        "shape": {"type": "string", "minLength": 1},
        "prior_identity_pinned": {"type": "boolean"},
        "mutable_current_symlink": {"const": false}
      }
    },
    "oci_build": {
      "anyOf": [
        {"type": "null"},
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "builder",
            "built",
            "image_id",
            "image_platform",
            "buildx_multiarch",
            "target_arch_match_verified"
          ],
          "properties": {
            "builder": {"anyOf": [{"type": "string", "minLength": 1}, {"type": "null"}]},
            "built": {"type": "boolean"},
            "image_id": {"anyOf": [{"type": "string", "minLength": 1}, {"type": "null"}]},
            "image_platform": {"anyOf": [{"type": "string", "minLength": 1}, {"type": "null"}]},
            "buildx_multiarch": {"const": false},
            "target_arch_match_verified": {"const": false}
          }
        }
      ]
    },
    "seams": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["seam_id", "offline_evaluable", "verdict", "evidence_class", "detail_digest", "note"],
        "properties": {
          "seam_id": {"type": "string", "minLength": 1},
          "offline_evaluable": {"type": "boolean"},
          "verdict": {"enum": ["OFFLINE_PROVEN", "STRUCTURAL_DESIGN", "DEFERRED_S1_6"]},
          "evidence_class": {"enum": ["LOCAL_REPRODUCIBLE", "STRUCTURAL_ONLY", "DEFERRED"]},
          "detail_digest": {"$ref": "#/$defs/digest"},
          "note": {"type": "string", "minLength": 1}
        }
      }
    },
    "source_sha256": {"$ref": "#/$defs/digest"},
    "schema_sha256": {"$ref": "#/$defs/digest"},
    "secret_scan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["patterns_checked", "leaked"],
      "properties": {
        "patterns_checked": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "leaked": {"const": false}
      }
    },
    "observation_time": {"$ref": "#/$defs/timestamp"},
    "expires_at": {"$ref": "#/$defs/timestamp"},
    "ttl_seconds": {"type": "integer", "minimum": 1, "maximum": 3600},
    "failure_reason": {"anyOf": [{"type": "string", "minLength": 1}, {"type": "null"}]},
    "self_digest": {"$ref": "#/$defs/digest"}
  },
  "allOf": [
    {
      "if": {"properties": {"status": {"const": "PASS"}}},
      "then": {
        "properties": {
          "target_class": {"const": "disposable_offline"},
          "evidence_class": {"const": "LOCAL_REPRODUCIBLE"},
          "failure_reason": {"type": "null"},
          "isolation_mode": {
            "properties": {
              "python_isolated_mode": {"const": true},
              "ignores_ambient_env": {"const": true}
            }
          },
          "seams": {
            "allOf": [
              {"contains": {"type": "object", "required": ["seam_id", "verdict"], "properties": {"seam_id": {"const": "native_lib_loading_target"}, "verdict": {"const": "DEFERRED_S1_6"}}}},
              {"contains": {"type": "object", "required": ["seam_id", "verdict"], "properties": {"seam_id": {"const": "cgroup_isolation"}, "verdict": {"const": "DEFERRED_S1_6"}}}},
              {"contains": {"type": "object", "required": ["seam_id", "verdict"], "properties": {"seam_id": {"const": "network_denial"}, "verdict": {"const": "DEFERRED_S1_6"}}}},
              {"contains": {"type": "object", "required": ["seam_id", "verdict"], "properties": {"seam_id": {"const": "start_stop_failure_cleanup"}, "verdict": {"const": "DEFERRED_S1_6"}}}},
              {"contains": {"type": "object", "required": ["seam_id", "verdict"], "properties": {"seam_id": {"const": "pg_identity_runtime"}, "verdict": {"const": "DEFERRED_S1_6"}}}}
            ]
          }
        }
      },
      "else": {
        "properties": {
          "failure_reason": {"type": "string", "minLength": 1}
        }
      }
    }
  ],
  "$defs": {
    "digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "timestamp": {"type": "string", "format": "date-time"}
  }
}

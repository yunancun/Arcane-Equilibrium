{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arcane-equilibrium.local/schemas/identity_acl_contract_receipt_v1.schema.json",
  "title": "identity_acl_contract_receipt_v1",
  "description": "Canonical self-hashed receipt emitted by identity_acl_contract_adapter_v1 (AIML LR0B, S1.3). A declarative least-privilege host-UID/PG-role/auth/socket-ACL/secret-lifecycle/rollback contract plus the fail-closed negative-ACL proof that an over-granting contract is REJECTED. S1.3 is disposable-only: production target is rejected fail-closed and every production_*_provisioned flag is const false (real provisioning is S2.0/S2.4). Evidence-authenticity contract (CLAUDE §四): a self-hashed receipt authenticates integrity only, never execution; evidence_class and the observation_source/mode_source/new_credential_connected fields are advisory caller-supplied labels, so a LOCAL_REPRODUCIBLE label on the receipt bytes alone is a self-attested summary, not proof of execution. Any S1.5/S2.4 consumer that relies on a LOCAL_REPRODUCIBLE identity/ACL receipt MUST re-run the disposable proof (or obtain platform attestation); it may not trust the evidence_class label alone.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "adapter_id",
    "status",
    "caller",
    "platform",
    "target_class",
    "evidence_class",
    "host_uid_topology",
    "pg_role_topology",
    "auth_mapping",
    "socket_dir_acl",
    "secret_lifecycle",
    "rollback",
    "negative_acl_cases",
    "source_sha256",
    "schema_sha256",
    "secret_scan",
    "observation_time",
    "expires_at",
    "ttl_seconds",
    "failure_reason",
    "self_digest"
  ],
  "properties": {
    "schema_version": {"const": "identity_acl_contract_receipt_v1"},
    "adapter_id": {"const": "identity_acl_contract_adapter_v1"},
    "status": {"enum": ["PASS", "FAIL"]},
    "caller": {"type": "string", "minLength": 1},
    "platform": {
      "type": "object",
      "additionalProperties": false,
      "required": ["os", "arch", "postgres_version"],
      "properties": {
        "os": {"enum": ["darwin", "linux"]},
        "arch": {"type": "string", "minLength": 1},
        "postgres_version": {"type": "string", "minLength": 1}
      }
    },
    "target_class": {"enum": ["disposable_local", "production"]},
    "evidence_class": {"enum": ["LOCAL_REPRODUCIBLE", "STRUCTURAL_ONLY"], "description": "Receipt-level ceiling = strongest non-deferred facet exercised. ADVISORY only: a self-hashed receipt cannot authenticate its own execution, so a LOCAL_REPRODUCIBLE label alone is a self-attested summary. A consumer MUST re-run the disposable proof or obtain platform attestation before trusting it."},
    "host_uid_topology": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "component", "uid_label", "non_root", "oci_socket_access",
          "dbus_authority", "least_privilege_caps", "evidence_class",
          "production_uid_provisioned"
        ],
        "properties": {
          "component": {"enum": ["engine_scanner", "controller", "fit_evaluation", "serving", "deleter"]},
          "uid_label": {"type": "string", "minLength": 1},
          "non_root": {"const": true},
          "oci_socket_access": {"const": false},
          "dbus_authority": {"const": false},
          "least_privilege_caps": {"type": "array", "items": {"type": "string", "minLength": 1}},
          "evidence_class": {"enum": ["STRUCTURAL_ONLY", "DEFERRED_S2"]},
          "production_uid_provisioned": {"const": false}
        }
      }
    },
    "pg_role_topology": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "component", "role_name", "privilege_class", "is_superuser",
          "forbidden_attrs_all_false", "is_reader", "writer_for_reader",
          "evidence_class", "production_role_provisioned"
        ],
        "properties": {
          "component": {"type": "string", "minLength": 1},
          "role_name": {"type": "string", "minLength": 1},
          "privilege_class": {
            "enum": [
              "observer_read_only", "scanner_capture_writer", "queue_writer",
              "fit_evaluation_writer", "serving_read_only", "retention_deleter"
            ]
          },
          "is_superuser": {"const": false},
          "forbidden_attrs_all_false": {"const": true},
          "is_reader": {"type": "boolean"},
          "writer_for_reader": {"const": false},
          "evidence_class": {"enum": ["LOCAL_REPRODUCIBLE", "STRUCTURAL_ONLY"]},
          "production_role_provisioned": {"const": false}
        }
      }
    },
    "auth_mapping": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "method", "local_only", "trust_from_anywhere", "wide_cidr",
        "ident_map", "evidence_class", "production_hba_installed"
      ],
      "properties": {
        "method": {"enum": ["pg_hba_ident_local", "pg_hba_scram_local", "authenticated_loopback"]},
        "local_only": {"const": true},
        "trust_from_anywhere": {"const": false},
        "wide_cidr": {"const": false},
        "ident_map": {"type": "null", "description": "S1.3 removes the ident_map free-form attack surface: it must be null (a bounded ident map is genuinely S2.4 scope)."},
        "evidence_class": {"enum": ["LOCAL_REPRODUCIBLE", "STRUCTURAL_ONLY"]},
        "production_hba_installed": {"const": false}
      }
    },
    "socket_dir_acl": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "component", "socket_dir_label", "mode", "mode_source", "world_readable",
          "world_writable", "owner_uid_label", "group_label", "evidence_class",
          "production_socket_provisioned"
        ],
        "properties": {
          "component": {"type": "string", "minLength": 1},
          "socket_dir_label": {"type": "string", "minLength": 1},
          "mode": {"type": "string", "pattern": "^0[0-7]{3}$"},
          "mode_source": {"enum": ["live_chmod_stat", "structural_contract"]},
          "world_readable": {"const": false},
          "world_writable": {"const": false},
          "owner_uid_label": {"type": "string", "minLength": 1},
          "group_label": {"type": "string", "minLength": 1},
          "evidence_class": {"enum": ["LOCAL_REPRODUCIBLE", "STRUCTURAL_ONLY"]},
          "production_socket_provisioned": {"const": false}
        }
      }
    },
    "secret_lifecycle": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rotation", "protected_loading", "plaintext_ingress", "evidence_class",
        "production_credential_rotated"
      ],
      "properties": {
        "rotation": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "secret_slot_target", "role_target", "old_fingerprint",
            "new_fingerprint", "rotation_order", "old_credential_rejection_proof"
          ],
          "properties": {
            "secret_slot_target": {"type": "string", "minLength": 1},
            "role_target": {"type": "string", "minLength": 1},
            "old_fingerprint": {"$ref": "#/$defs/digest"},
            "new_fingerprint": {"$ref": "#/$defs/digest"},
            "rotation_order": {"type": "array", "minItems": 3, "items": {"type": "string", "minLength": 1}},
            "old_credential_rejection_proof": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "attempted", "observed_sqlstate", "verdict", "observation_source",
                "new_credential_connected"
              ],
              "properties": {
                "attempted": {"type": "string", "minLength": 1},
                "observed_sqlstate": {"$ref": "#/$defs/sqlstate"},
                "verdict": {"const": "DENIED"},
                "observation_source": {"enum": ["live_disposable_pg", "structural_contract"]},
                "new_credential_connected": {"type": "boolean"}
              }
            }
          }
        },
        "protected_loading": {
          "type": "object",
          "additionalProperties": false,
          "required": ["no_plaintext_ingress", "loader_kind"],
          "properties": {
            "no_plaintext_ingress": {"const": true},
            "loader_kind": {"type": "string", "minLength": 1}
          }
        },
        "plaintext_ingress": {"const": false},
        "evidence_class": {"enum": ["LOCAL_REPRODUCIBLE", "STRUCTURAL_ONLY"]},
        "production_credential_rotated": {"const": false}
      }
    },
    "rollback": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["change_id", "change_kind", "pre_state_digest", "rollback_action", "recovery"],
        "properties": {
          "change_id": {"type": "string", "minLength": 1},
          "change_kind": {"enum": ["host_uid", "pg_role", "auth_mapping", "socket_acl", "secret_slot"]},
          "pre_state_digest": {"$ref": "#/$defs/digest"},
          "rollback_action": {"type": "string", "minLength": 1},
          "recovery": {"enum": ["rollback", "approved_forward_only"]}
        }
      }
    },
    "negative_acl_cases": {
      "type": "array",
      "minItems": 10,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["case_id", "over_grant_kind", "expected", "observed_verdict", "evidence_class", "reason"],
        "properties": {
          "case_id": {"type": "string", "minLength": 1},
          "over_grant_kind": {
            "enum": [
              "writer_role_for_reader", "shared_uid", "root_uid",
              "world_readable_socket", "superuser_role",
              "trust_auth_from_anywhere", "wide_cidr", "missing_rollback",
              "controller_oci_socket_or_dbus", "plaintext_secret_ingress"
            ]
          },
          "expected": {"const": "FAIL_CLOSED"},
          "observed_verdict": {"const": "REJECTED"},
          "evidence_class": {"enum": ["LOCAL_REPRODUCIBLE", "STRUCTURAL_ONLY"]},
          "reason": {"type": "string", "minLength": 1}
        }
      }
    },
    "source_sha256": {"$ref": "#/$defs/digest"},
    "schema_sha256": {"$ref": "#/$defs/digest"},
    "secret_scan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["patterns_checked", "leaked"],
      "properties": {
        "patterns_checked": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "leaked": {"const": false}
      }
    },
    "observation_time": {"$ref": "#/$defs/timestamp"},
    "expires_at": {"$ref": "#/$defs/timestamp"},
    "ttl_seconds": {"type": "integer", "minimum": 1, "maximum": 3600},
    "failure_reason": {"anyOf": [{"type": "string", "minLength": 1}, {"type": "null"}]},
    "self_digest": {"$ref": "#/$defs/digest"}
  },
  "allOf": [
    {
      "if": {"properties": {"status": {"const": "PASS"}}},
      "then": {
        "properties": {
          "target_class": {"const": "disposable_local"},
          "failure_reason": {"type": "null"}
        }
      },
      "else": {
        "properties": {
          "failure_reason": {"type": "string", "minLength": 1}
        }
      }
    }
  ],
  "$defs": {
    "digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "timestamp": {"type": "string", "format": "date-time"},
    "sqlstate": {"type": "string", "pattern": "^[0-9A-Z]{5}$"}
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arcane-equilibrium.local/schemas/learning_runtime_choice_receipt_v1.schema.json",
  "title": "learning_runtime_choice_receipt_v1",
  "description": "Canonical self-hashed receipt emitted by runtime_choice_probe_v1 (AIML LR0C, S1.6). It (1) records the ISOLATED disposable-local runtime probe (reusing S1.5's LEARNING_RUNTIME temp_dir_artifact apply/rollback/postcheck lifecycle) for BOTH candidates, (2) records the honest disposable-proven vs target-host-deferred seam split, (3) makes the final single-runtime choice (content_addressed_fixed_path) under the plan's asymmetric rule, and (4) forecloses the unselected OCI production path. It attests NOTHING running: production_running_attested and every boundary running flag are const false; target_host_probe_performed is honestly false on the Mac deliverable so oci_selectable is const false and final_choice is fixed-path. It SUPERSEDES the S1.4 runtime_candidate_comparison_v1 const-null by binding it by digest (never editing it). The plan's selection rule (oci_selectable == target_host_probe_performed AND all OCI target-host seams passed) and the cross-field PASS cruxes are enforced in the delegated Python validator, not schema if/then. ACCEPTANCE CONTRACT (evidence honesty, mirrors S1.3): a LOCAL_REPRODUCIBLE PASS's per-candidate probe evidence (applied_digest / lifecycle_result_digest / postcheck_attestation_digest / disposable_seams_proven, including the disposable_pg_identity 42501 evidence_digest) is a SELF-ATTESTED SUMMARY. The self_digest proves integrity, not authenticity (CLAUDE.md). A consumer relying on this receipt as the S1-exit runtime probe MUST re-run the builder or obtain trusted-host attestation: it cannot recompute lifecycle_result_digest/postcheck_attestation_digest from the S1.5 result objects (absent from the receipt bytes) alone. The standalone validator additionally only FORMAT-checks the bound S1.4 A/B/comparison digests; a trusted-host re-validation MUST re-fetch the S1.4 comparison by digest and re-assert final_choice is null.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "harness_id",
    "status",
    "caller",
    "target_class",
    "platform",
    "probe_scope",
    "candidate_probes",
    "selection",
    "unselected_path_removal",
    "production_running_attested",
    "dependency_receipts",
    "boundary",
    "supersedes_comparison_null",
    "source_sha256",
    "schema_sha256",
    "secret_scan",
    "observation_time",
    "expires_at",
    "ttl_seconds",
    "failure_reason",
    "self_digest"
  ],
  "properties": {
    "schema_version": {"const": "learning_runtime_choice_receipt_v1"},
    "harness_id": {"const": "runtime_choice_probe_v1"},
    "status": {"enum": ["PASS", "FAIL"]},
    "caller": {"type": "string", "minLength": 1},
    "target_class": {"enum": ["disposable_local", "target_host"]},
    "platform": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "os",
        "arch",
        "python_version",
        "container_runtime",
        "container_runtime_available",
        "buildx_available",
        "target_host_container_runtime_available"
      ],
      "properties": {
        "os": {"enum": ["darwin", "linux"]},
        "arch": {"type": "string", "minLength": 1},
        "python_version": {"type": "string", "minLength": 1},
        "container_runtime": {"anyOf": [{"type": "string", "minLength": 1}, {"type": "null"}]},
        "container_runtime_available": {"type": "boolean"},
        "buildx_available": {"type": "boolean"},
        "target_host_container_runtime_available": {"const": false}
      }
    },
    "probe_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "effect_class",
        "disposable_probe_performed",
        "target_host_probe_performed",
        "target_host_deferred_to"
      ],
      "properties": {
        "effect_class": {"const": "TARGET_HOST_DISPOSABLE_RUNTIME_PROBE"},
        "disposable_probe_performed": {"const": true},
        "target_host_probe_performed": {"type": "boolean"},
        "target_host_deferred_to": {"const": "S2.3_sealed_build_and_S2.5_running_attestation"}
      }
    },
    "candidate_probes": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "candidate_id",
          "runtime_identity_kind",
          "lifecycle_result_digest",
          "postcheck_attestation_digest",
          "apply_actor_node",
          "postcheck_verifier_node",
          "pre_state_digest",
          "applied_digest",
          "post_rollback_digest",
          "representativeness",
          "disposable_seams_proven",
          "target_host_deferred_seams",
          "caveats",
          "evidence_class"
        ],
        "properties": {
          "candidate_id": {"enum": ["exact_image_id_oci", "content_addressed_fixed_path"]},
          "runtime_identity_kind": {"enum": ["exact_image_id", "content_addressed_path"]},
          "lifecycle_result_digest": {"$ref": "#/$defs/digest"},
          "postcheck_attestation_digest": {"$ref": "#/$defs/digest"},
          "apply_actor_node": {"type": "string", "minLength": 1},
          "postcheck_verifier_node": {"type": "string", "minLength": 1},
          "pre_state_digest": {"$ref": "#/$defs/digest"},
          "applied_digest": {"$ref": "#/$defs/digest"},
          "post_rollback_digest": {"$ref": "#/$defs/digest"},
          "representativeness": {"enum": ["native_shape", "content_addressed_standin"]},
          "disposable_seams_proven": {
            "type": "array",
            "minItems": 6,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["seam_id", "verdict", "evidence_class"],
              "properties": {
                "seam_id": {"type": "string", "minLength": 1},
                "verdict": {"const": "DISPOSABLE_PROVEN"},
                "evidence_class": {"enum": ["LOCAL_REPRODUCIBLE", "STRUCTURAL_ONLY"]},
                "evidence_digest": {"$ref": "#/$defs/digest"}
              }
            }
          },
          "target_host_deferred_seams": {
            "type": "array",
            "minItems": 6,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["seam_id", "verdict"],
              "properties": {
                "seam_id": {"type": "string", "minLength": 1},
                "verdict": {"const": "DEFERRED_TARGET_HOST"}
              }
            }
          },
          "caveats": {"type": "array", "items": {"type": "string", "minLength": 1}},
          "evidence_class": {"enum": ["LOCAL_REPRODUCIBLE", "STRUCTURAL_ONLY"]}
        }
      }
    },
    "selection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "final_choice",
        "selection_rule",
        "selection_basis",
        "reason",
        "binding",
        "oci_selectable"
      ],
      "properties": {
        "final_choice": {"enum": ["content_addressed_fixed_path", "exact_image_id_oci"]},
        "selection_rule": {"const": "oci_only_if_all_seams_pass_else_fixed_path"},
        "selection_basis": {
          "type": "array",
          "minItems": 3,
          "items": {
            "enum": [
              "oci_all_seams_pass_precondition_unmet",
              "lr2_no_oci_socket_dbus_constraint",
              "fixed_path_offline_and_disposable_seams_proven"
            ]
          }
        },
        "reason": {"const": "OCI's decisive isolation seams are not satisfiable in the available disposable/target-host-deferred evidence; fixed-path satisfies the offline-provable seams and LR2's no-OCI-socket constraint."},
        "binding": {"enum": ["BINDING", "PROVISIONAL_PENDING_LINUX"]},
        "oci_selectable": {"const": false}
      }
    },
    "unselected_path_removal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "unselected_candidate",
        "unselected_production_artifact_present",
        "production_path_removed",
        "forecloses_downstream",
        "note"
      ],
      "properties": {
        "unselected_candidate": {"const": "exact_image_id_oci"},
        "unselected_production_artifact_present": {"const": false},
        "production_path_removed": {"const": true},
        "forecloses_downstream": {"const": true},
        "note": {"type": "string", "minLength": 1}
      }
    },
    "production_running_attested": {"const": false},
    "dependency_receipts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "runtime_candidate_receipt_a_digest",
        "runtime_candidate_receipt_b_digest",
        "runtime_candidate_comparison_digest",
        "effect_seams_ready_receipt_digest",
        "component_effect_matrix_digest",
        "pg_readonly_identity_receipt_digest"
      ],
      "properties": {
        "runtime_candidate_receipt_a_digest": {"$ref": "#/$defs/digest"},
        "runtime_candidate_receipt_b_digest": {"$ref": "#/$defs/digest"},
        "runtime_candidate_comparison_digest": {"$ref": "#/$defs/digest"},
        "effect_seams_ready_receipt_digest": {"$ref": "#/$defs/digest"},
        "component_effect_matrix_digest": {"$ref": "#/$defs/digest"},
        "pg_readonly_identity_receipt_digest": {"$ref": "#/$defs/digest"}
      }
    },
    "boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "production_running_attested",
        "real_target_host_probe_on_mac",
        "real_process_started",
        "native_lib_loaded_on_target",
        "kernel_isolation_exercised",
        "network_contact",
        "nine_authorities_false"
      ],
      "properties": {
        "production_running_attested": {"const": false},
        "real_target_host_probe_on_mac": {"const": false},
        "real_process_started": {"const": false},
        "native_lib_loaded_on_target": {"const": false},
        "kernel_isolation_exercised": {"const": false},
        "network_contact": {"const": false},
        "nine_authorities_false": {"const": true}
      }
    },
    "supersedes_comparison_null": {"const": true},
    "source_sha256": {"$ref": "#/$defs/digest"},
    "schema_sha256": {"$ref": "#/$defs/digest"},
    "secret_scan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["patterns_checked", "leaked"],
      "properties": {
        "patterns_checked": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "leaked": {"const": false}
      }
    },
    "observation_time": {"$ref": "#/$defs/timestamp"},
    "expires_at": {"$ref": "#/$defs/timestamp"},
    "ttl_seconds": {"type": "integer", "minimum": 1, "maximum": 3600},
    "failure_reason": {"anyOf": [{"type": "string", "minLength": 1}, {"type": "null"}]},
    "self_digest": {"$ref": "#/$defs/digest"}
  },
  "allOf": [
    {
      "if": {"properties": {"status": {"const": "PASS"}}},
      "then": {
        "properties": {
          "target_class": {"const": "disposable_local"},
          "failure_reason": {"type": "null"},
          "probe_scope": {
            "properties": {"target_host_probe_performed": {"const": false}}
          },
          "selection": {
            "properties": {
              "final_choice": {"const": "content_addressed_fixed_path"},
              "oci_selectable": {"const": false}
            }
          }
        }
      },
      "else": {
        "properties": {
          "failure_reason": {"type": "string", "minLength": 1}
        }
      }
    }
  ],
  "$defs": {
    "digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "timestamp": {"type": "string", "format": "date-time"}
  }
}

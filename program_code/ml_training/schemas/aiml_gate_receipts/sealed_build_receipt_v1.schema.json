{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arcane-equilibrium.local/schemas/sealed_build_receipt_v1.schema.json",
  "title": "sealed_build_receipt_v1",
  "description": "Canonical self-hashed receipt emitted by sealed_build_adapter_v1 for AIML LR2 (S2.3). It seals the fully-resolved, hash-pinned Linux dependency closure (requirements-ml.lock, produced once by uv pip compile --generate-hashes) for the S1.6-selected content_addressed_fixed_path runtime, and flips the three S1.4 deferred consts truthfully: dependency_closure.real_ml_closure_resolved is now true, sealed_input.reproducible_output_verified is now true, and the launch contract is absolute_pinned / python_isolated_mode. S2.3 is NONE-effect (source + build-verification only): native_library_inventory[].load_verified_on_target stays const false (dlopen on the Linux target is S2.5/LR6), boundary.production_installed stays false (installing is S2.4), and boundary.production_running_attested / target_host_loaded stay false. runtime_content_digest is the content-addressed identity over {closure_hash, isolated_launch_config, native_lib_inventory_digest, python_version, target_platform}; the delegated Python validator re-derives it and enforces the cross-field cruxes (schema if/then only guards PASS => failure_reason null). Evidence-authenticity contract (CLAUDE.md): a self-hashed receipt authenticates the lock closure integrity only, never that the wheels installed, imported, or that the .so loaded on the target.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "adapter_id",
    "status",
    "caller",
    "platform",
    "closure_hash",
    "runtime_content_digest",
    "lock_tool",
    "lock_input_ref",
    "dependency_closure",
    "sealed_input",
    "launch",
    "native_library_inventory",
    "boundary",
    "learning_runtime_choice_receipt_digest",
    "runtime_candidate_receipt_b_digest",
    "source_sha256",
    "schema_sha256",
    "secret_scan",
    "observation_time",
    "expires_at",
    "ttl_seconds",
    "failure_reason",
    "self_digest"
  ],
  "properties": {
    "schema_version": {"const": "sealed_build_receipt_v1"},
    "adapter_id": {"const": "sealed_build_adapter_v1"},
    "status": {"enum": ["PASS", "FAIL"]},
    "caller": {"type": "string", "minLength": 1},
    "platform": {
      "type": "object",
      "additionalProperties": false,
      "required": ["os", "arch", "python_version", "target_platform"],
      "properties": {
        "os": {"enum": ["darwin", "linux"]},
        "arch": {"type": "string", "minLength": 1},
        "python_version": {"type": "string", "minLength": 1},
        "target_platform": {"type": "string", "minLength": 1}
      }
    },
    "closure_hash": {"$ref": "#/$defs/digest"},
    "runtime_content_digest": {"$ref": "#/$defs/digest"},
    "lock_tool": {"type": "string", "minLength": 1},
    "lock_input_ref": {"type": "string", "minLength": 1},
    "dependency_closure": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "real_ml_closure_resolved",
        "unpinned_count",
        "entries_total",
        "hashed_entries_total"
      ],
      "properties": {
        "real_ml_closure_resolved": {"const": true},
        "unpinned_count": {"const": 0},
        "entries_total": {"type": "integer", "minimum": 1},
        "hashed_entries_total": {"type": "integer", "minimum": 0}
      }
    },
    "sealed_input": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reproducible_output_verified",
        "mutable_tag_or_alias",
        "relocatable_renamed_venv"
      ],
      "properties": {
        "reproducible_output_verified": {"const": true},
        "mutable_tag_or_alias": {"const": false},
        "relocatable_renamed_venv": {"const": false}
      }
    },
    "launch": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "launch_interpreter",
        "system_python_fallback_possible",
        "python_isolated_mode",
        "ignores_ambient_env"
      ],
      "properties": {
        "launch_interpreter": {"const": "absolute_pinned"},
        "system_python_fallback_possible": {"const": false},
        "python_isolated_mode": {"const": true},
        "ignores_ambient_env": {"const": true}
      }
    },
    "native_library_inventory": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["package", "version", "wheel_sha256", "load_verified_on_target"],
        "properties": {
          "package": {"type": "string", "minLength": 1},
          "version": {"type": "string", "minLength": 1},
          "wheel_sha256": {"$ref": "#/$defs/digest"},
          "load_verified_on_target": {"const": false}
        }
      }
    },
    "boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "production_installed",
        "production_running_attested",
        "target_host_loaded",
        "nine_authorities_false"
      ],
      "properties": {
        "production_installed": {"const": false},
        "production_running_attested": {"const": false},
        "target_host_loaded": {"const": false},
        "nine_authorities_false": {"const": true}
      }
    },
    "learning_runtime_choice_receipt_digest": {"$ref": "#/$defs/digest"},
    "runtime_candidate_receipt_b_digest": {"$ref": "#/$defs/digest"},
    "source_sha256": {"$ref": "#/$defs/digest"},
    "schema_sha256": {"$ref": "#/$defs/digest"},
    "secret_scan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["patterns_checked", "leaked"],
      "properties": {
        "patterns_checked": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "leaked": {"const": false}
      }
    },
    "observation_time": {"$ref": "#/$defs/timestamp"},
    "expires_at": {"$ref": "#/$defs/timestamp"},
    "ttl_seconds": {"type": "integer", "minimum": 1, "maximum": 3600},
    "failure_reason": {"anyOf": [{"type": "string", "minLength": 1}, {"type": "null"}]},
    "self_digest": {"$ref": "#/$defs/digest"}
  },
  "allOf": [
    {
      "if": {"properties": {"status": {"const": "PASS"}}},
      "then": {
        "properties": {
          "failure_reason": {"type": "null"}
        }
      },
      "else": {
        "properties": {
          "failure_reason": {"type": "string", "minLength": 1}
        }
      }
    }
  ],
  "$defs": {
    "digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "timestamp": {"type": "string", "format": "date-time"}
  }
}

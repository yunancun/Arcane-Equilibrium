{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "effect_seams_ready_receipt_v1.schema.json",
  "title": "Effect-seams-ready rollup receipt (S1.5 contribution)",
  "description": "A thin rollup binding, by digest, the six per-component disposable apply/rollback/postcheck results plus governance-wiring, observation-seam, bypass-negative and S1.1-S1.4 dependency evidence. sprint_gate_scope is const S1.5_CONTRIBUTION: this receipt asserts only the S1.5 contribution, not the full Sprint-1 EFFECT_SEAMS_READY gate (S1.6 also contributes). production_apply_performed and the boundary const-false flags make no-production-apply machine-enforced. Each admitted class also carries reobserved_post_rollback_digest, the independent verifier's re-derived post digest, which the delegated Python validator re-checks equals post_rollback_digest so the distinct-actor postcheck is load-bearing. PASS-critical cross-field checks (pre==post per class, reobserved==post per class, verifier!=applier, every bypass kind present) are enforced in the delegated Python validator, not schema if/then.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "harness_id", "status", "caller", "target_class", "governance_wiring", "admitted_classes", "observation_seam", "bypass_negatives", "dependency_receipts", "boundary", "sprint_gate_scope", "source_sha256", "schema_sha256", "secret_scan", "observation_time", "expires_at", "ttl_seconds", "failure_reason", "self_digest"],
  "properties": {
    "schema_version": {"const": "effect_seams_ready_receipt_v1"},
    "harness_id": {"const": "component_effect_seams_harness_v1"},
    "status": {"enum": ["PASS", "FAIL"]},
    "caller": {"type": "string", "minLength": 1},
    "target_class": {"enum": ["disposable_local", "production"]},
    "governance_wiring": {
      "type": "object",
      "additionalProperties": false,
      "required": ["component_effect_matrix_digest", "registered_adapter_ids", "schema_files_registered", "central_validator_recognizes", "generated_views_unchanged"],
      "properties": {
        "component_effect_matrix_digest": {"$ref": "#/$defs/digest"},
        "registered_adapter_ids": {"type": "array", "minItems": 6, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "schema_files_registered": {"type": "array", "minItems": 4, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "central_validator_recognizes": {"const": true},
        "generated_views_unchanged": {"const": true}
      }
    },
    "admitted_classes": {
      "type": "array",
      "minItems": 6,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["effect_class", "adapter_id", "disposable_target_kind", "intent_digest", "pre_state_digest", "result_digest", "post_rollback_digest", "reobserved_post_rollback_digest", "rollback_restored_exact", "apply_actor_node", "postcheck_attestation_digest", "postcheck_verifier_node", "applier_is_not_sole_verifier", "evidence_class", "production_apply_performed"],
        "properties": {
          "effect_class": {"enum": ["ENGINE_SCANNER", "LEARNING_RUNTIME", "CONTROLLER_WORKERS", "RETENTION_APPLY", "PG_ROLE_ACL_MIGRATION", "CREDENTIAL_ROTATION"]},
          "adapter_id": {"type": "string", "minLength": 1},
          "disposable_target_kind": {"enum": ["disposable_pg", "temp_dir_artifact", "temp_dir_objects"]},
          "intent_digest": {"$ref": "#/$defs/digest"},
          "pre_state_digest": {"$ref": "#/$defs/digest"},
          "result_digest": {"$ref": "#/$defs/digest"},
          "post_rollback_digest": {"$ref": "#/$defs/digest"},
          "reobserved_post_rollback_digest": {"$ref": "#/$defs/digest"},
          "rollback_restored_exact": {"const": true},
          "apply_actor_node": {"type": "string", "minLength": 1},
          "postcheck_attestation_digest": {"$ref": "#/$defs/digest"},
          "postcheck_verifier_node": {"type": "string", "minLength": 1},
          "applier_is_not_sole_verifier": {"const": true},
          "evidence_class": {"enum": ["LOCAL_REPRODUCIBLE", "STRUCTURAL_ONLY"]},
          "production_apply_performed": {"const": false}
        }
      }
    },
    "observation_seam": {
      "type": "object",
      "additionalProperties": false,
      "required": ["seam_kind", "remote_platform_attested", "attestation_schema", "deferred_to"],
      "properties": {
        "seam_kind": {"const": "independent_distinct_actor_postcheck"},
        "remote_platform_attested": {"const": false},
        "attestation_schema": {"const": "component_effect_postcheck_attestation_v1"},
        "deferred_to": {"const": "S2.5_running_attestation_and_S1.6_target_host_probe"}
      }
    },
    "bypass_negatives": {
      "type": "array",
      "minItems": 12,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["case_id", "bypass_kind", "expected", "observed_verdict", "evidence_class"],
        "properties": {
          "case_id": {"type": "string", "minLength": 1},
          "bypass_kind": {"type": "string", "minLength": 1},
          "expected": {"const": "FAIL_CLOSED"},
          "observed_verdict": {"const": "REJECTED"},
          "evidence_class": {"enum": ["LOCAL_REPRODUCIBLE", "STRUCTURAL_ONLY"]}
        }
      }
    },
    "dependency_receipts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pg_readonly_identity_receipt_digest", "component_effect_matrix_digest", "worm_sink_status", "identity_acl_contract_receipt_digest", "runtime_candidate_receipt_a_digest", "runtime_candidate_receipt_b_digest"],
      "properties": {
        "pg_readonly_identity_receipt_digest": {"$ref": "#/$defs/digest"},
        "component_effect_matrix_digest": {"$ref": "#/$defs/digest"},
        "worm_sink_status": {"type": "string", "minLength": 1},
        "identity_acl_contract_receipt_digest": {"$ref": "#/$defs/digest"},
        "runtime_candidate_receipt_a_digest": {"$ref": "#/$defs/digest"},
        "runtime_candidate_receipt_b_digest": {"$ref": "#/$defs/digest"}
      }
    },
    "boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["production_apply_performed", "real_service_restart", "real_remote_host_mutation", "real_migration_applied", "nine_authorities_false"],
      "properties": {
        "production_apply_performed": {"const": false},
        "real_service_restart": {"const": false},
        "real_remote_host_mutation": {"const": false},
        "real_migration_applied": {"const": false},
        "nine_authorities_false": {"const": true}
      }
    },
    "sprint_gate_scope": {"const": "S1.5_CONTRIBUTION"},
    "source_sha256": {"$ref": "#/$defs/digest"},
    "schema_sha256": {"$ref": "#/$defs/digest"},
    "secret_scan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["patterns_checked", "leaked"],
      "properties": {
        "patterns_checked": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "leaked": {"const": false}
      }
    },
    "observation_time": {"$ref": "#/$defs/timestamp"},
    "expires_at": {"$ref": "#/$defs/timestamp"},
    "ttl_seconds": {"type": "integer", "minimum": 1, "maximum": 3600},
    "failure_reason": {"anyOf": [{"type": "string", "minLength": 1}, {"type": "null"}]},
    "self_digest": {"$ref": "#/$defs/digest"}
  },
  "$defs": {
    "digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "timestamp": {"type": "string", "format": "date-time"}
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arcane-equilibrium.local/schemas/pg_readonly_identity_receipt_v1.schema.json",
  "title": "pg_readonly_identity_receipt_v1",
  "description": "Canonical self-hashed receipt emitted by pg_readonly_identity_adapter_v1 after a disposable-cluster read-only identity proof. S1.1 (LR0A) is disposable-only: production PG is rejected fail-closed.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "adapter_id",
    "status",
    "caller",
    "platform",
    "target_class",
    "evidence_class",
    "endpoint",
    "database",
    "role",
    "session_read_only",
    "ambient_routing_scrubbed",
    "queries",
    "result_digest",
    "negative_cases",
    "source_sha256",
    "schema_sha256",
    "secret_scan",
    "observation_time",
    "expires_at",
    "ttl_seconds",
    "failure_reason",
    "self_digest"
  ],
  "properties": {
    "schema_version": {"const": "pg_readonly_identity_receipt_v1"},
    "adapter_id": {"const": "pg_readonly_identity_adapter_v1"},
    "status": {"enum": ["PASS", "FAIL"]},
    "caller": {"type": "string", "minLength": 1},
    "platform": {
      "type": "object",
      "additionalProperties": false,
      "required": ["os", "arch", "postgres_version"],
      "properties": {
        "os": {"enum": ["darwin", "linux"]},
        "arch": {"type": "string", "minLength": 1},
        "postgres_version": {"type": "string", "minLength": 1}
      }
    },
    "target_class": {"enum": ["disposable_local", "production"]},
    "evidence_class": {"enum": ["LOCAL_REPRODUCIBLE", "STRUCTURAL_ONLY"]},
    "endpoint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["endpoint_class", "socket_dir", "loopback_host", "port", "allowlisted"],
      "properties": {
        "endpoint_class": {"enum": ["unix_socket_allowlisted", "authenticated_loopback"]},
        "socket_dir": {"anyOf": [{"type": "string", "minLength": 1}, {"type": "null"}]},
        "loopback_host": {"anyOf": [{"enum": ["127.0.0.1", "::1"]}, {"type": "null"}]},
        "port": {"anyOf": [{"type": "integer", "minimum": 1, "maximum": 65535}, {"type": "null"}]},
        "allowlisted": {"const": true}
      }
    },
    "database": {"type": "string", "minLength": 1},
    "role": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "attributes", "is_read_only"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "attributes": {
          "type": "object",
          "additionalProperties": false,
          "required": ["rolsuper", "rolcreaterole", "rolcreatedb", "rolbypassrls", "rolreplication", "rolcanlogin"],
          "properties": {
            "rolsuper": {"type": "boolean"},
            "rolcreaterole": {"type": "boolean"},
            "rolcreatedb": {"type": "boolean"},
            "rolbypassrls": {"type": "boolean"},
            "rolreplication": {"type": "boolean"},
            "rolcanlogin": {"type": "boolean"}
          }
        },
        "is_read_only": {"type": "boolean"}
      }
    },
    "session_read_only": {"enum": ["on", "off"]},
    "ambient_routing_scrubbed": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dropped_env_keys",
        "psqlrc_neutralized",
        "service_file_neutralized",
        "pgsysconfdir_isolated",
        "effective_env_has_no_pg_routing"
      ],
      "properties": {
        "dropped_env_keys": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "psqlrc_neutralized": {"const": true},
        "service_file_neutralized": {"const": true},
        "pgsysconfdir_isolated": {"const": true},
        "effective_env_has_no_pg_routing": {"const": true}
      }
    },
    "queries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["query_id", "query_sha256", "row_count", "result_digest"],
        "properties": {
          "query_id": {"type": "string", "minLength": 1},
          "query_sha256": {"$ref": "#/$defs/digest"},
          "row_count": {"type": "integer", "minimum": 0},
          "result_digest": {"$ref": "#/$defs/digest"}
        }
      }
    },
    "result_digest": {"$ref": "#/$defs/digest"},
    "negative_cases": {
      "type": "object",
      "additionalProperties": false,
      "required": ["write_denied", "role_escalation_denied", "search_path_pinned"],
      "properties": {
        "write_denied": {
          "type": "object",
          "additionalProperties": false,
          "required": ["attempted", "expected_denial", "observed_sqlstate", "verdict"],
          "properties": {
            "attempted": {"type": "string", "minLength": 1},
            "expected_denial": {"const": true},
            "observed_sqlstate": {"$ref": "#/$defs/sqlstate"},
            "verdict": {"const": "DENIED"}
          }
        },
        "role_escalation_denied": {
          "type": "object",
          "additionalProperties": false,
          "required": ["attempted", "expected_denial", "observed_sqlstate", "verdict"],
          "properties": {
            "attempted": {"type": "string", "minLength": 1},
            "expected_denial": {"const": true},
            "observed_sqlstate": {"$ref": "#/$defs/sqlstate"},
            "verdict": {"const": "DENIED"}
          }
        },
        "search_path_pinned": {
          "type": "object",
          "additionalProperties": false,
          "required": ["attempted", "effective_search_path", "observed_sqlstate", "pinned", "verdict"],
          "properties": {
            "attempted": {"type": "string", "minLength": 1},
            "effective_search_path": {"type": "string", "minLength": 1},
            "observed_sqlstate": {"$ref": "#/$defs/sqlstate"},
            "pinned": {"const": true},
            "verdict": {"const": "DENIED"}
          }
        }
      }
    },
    "source_sha256": {"$ref": "#/$defs/digest"},
    "schema_sha256": {"$ref": "#/$defs/digest"},
    "secret_scan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["patterns_checked", "leaked"],
      "properties": {
        "patterns_checked": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "leaked": {"const": false}
      }
    },
    "observation_time": {"$ref": "#/$defs/timestamp"},
    "expires_at": {"$ref": "#/$defs/timestamp"},
    "ttl_seconds": {"type": "integer", "minimum": 1, "maximum": 3600},
    "failure_reason": {"anyOf": [{"type": "string", "minLength": 1}, {"type": "null"}]},
    "self_digest": {"$ref": "#/$defs/digest"}
  },
  "allOf": [
    {
      "if": {"properties": {"status": {"const": "PASS"}}},
      "then": {
        "properties": {
          "evidence_class": {"const": "LOCAL_REPRODUCIBLE"},
          "target_class": {"const": "disposable_local"},
          "failure_reason": {"type": "null"},
          "session_read_only": {"const": "on"},
          "role": {
            "properties": {
              "is_read_only": {"const": true},
              "attributes": {
                "properties": {
                  "rolsuper": {"const": false},
                  "rolcreaterole": {"const": false},
                  "rolcreatedb": {"const": false},
                  "rolbypassrls": {"const": false},
                  "rolreplication": {"const": false},
                  "rolcanlogin": {"const": true}
                }
              }
            }
          },
          "negative_cases": {
            "properties": {
              "write_denied": {
                "properties": {
                  "observed_sqlstate": {"const": "25006"}
                }
              },
              "search_path_pinned": {
                "properties": {
                  "verdict": {"const": "DENIED"},
                  "observed_sqlstate": {"const": "25006"}
                }
              }
            }
          }
        }
      },
      "else": {
        "properties": {
          "failure_reason": {"type": "string", "minLength": 1}
        }
      }
    }
  ],
  "$defs": {
    "digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "timestamp": {"type": "string", "format": "date-time"},
    "sqlstate": {"type": "string", "pattern": "^[0-9A-Z]{5}$"}
  }
}

# ═══════════════════════════════════════════════════════════════════════════
# OpenClaw / Bybit Control API v1 — 环境变量参考 / Environment Variables Reference
# ═══════════════════════════════════════════════════════════════════════════
#
# 复制此文件为 .env 并修改值后即可用于本地启动或 docker compose。
# Copy this file to .env and modify values for local startup or docker compose.
#
# 安全提示 / Safety note:
#   .env 文件包含敏感信息，不应提交到 Git。.gitignore 已排除。
#   .env files contain secrets and must NOT be committed. .gitignore excludes them.
# ═══════════════════════════════════════════════════════════════════════════

# ── 认证 / Authentication ──────────────────────────────────────────────────
# API 访问令牌（Bearer Token）。生产环境必须替换为强密钥。
# API access token (Bearer Token). MUST be replaced with a strong secret in production.
OPENCLAW_API_TOKEN=change-me

# ── 操作员身份 / Operator Identity ─────────────────────────────────────────
# 认证后的操作员 ID / 类型 / 角色 / 权限范围
# Authenticated operator ID / type / roles / scopes after auth
OPENCLAW_AUTH_ACTOR_ID=demo-operator
OPENCLAW_AUTH_ACTOR_TYPE=human
OPENCLAW_AUTH_ROLES=viewer,operator,operator_guarded,config_admin,finance_input
OPENCLAW_AUTH_SCOPES=state:read,learning:read,control:recheck,control:validate,control:arm,control:enable,control:relock,control:bundle,input:cost,input:event,input:note,input:config

# ── 状态存储 / State Storage ───────────────────────────────────────────────
# 控制状态 JSON 文件路径（自动创建）
# Control state JSON file path (auto-created on first run)
OPENCLAW_STATE_FILE=runtime/openclaw_bybit_control_state.json

# ── 连接器身份 / Connector Identity ────────────────────────────────────────
# 只读连接器名称（事实来源）
# Readonly connector name (fact source)
OPENCLAW_READONLY_CONNECTOR_NAME=bybit_prod_readonly_main

# 执行连接器名称（留空 = not_attached，当前阶段不启用）
# Execution connector name (empty = not_attached, not enabled at this stage)
OPENCLAW_EXECUTION_CONNECTOR_NAME=

# ── 连接状态覆盖 / Connection State Overrides ──────────────────────────────
# 以下字段可覆盖默认连接状态（用于测试 / 模拟降级场景）
# These fields override default connection states (for testing / simulating degradation)
# 可选值 / Allowed values: ready | degraded | down | unknown
OPENCLAW_REST_PRIVATE_CONNECTION_STATE=ready
OPENCLAW_WS_PRIVATE_CONNECTION_STATE=ready

# 可选值 / Allowed values: healthy | degraded | down | unknown
OPENCLAW_RUNTIME_CONNECTION_STATE=healthy

# 可选值 / Allowed values: complete | partial | missing | unknown
OPENCLAW_ACCOUNT_FACT_COMPLETENESS_STATE=complete
OPENCLAW_SOURCE_SNAPSHOT_COMPLETENESS_STATE=complete

# ── Runtime 快照桥接（可选）/ Runtime Snapshot Bridge (optional) ────────────
# 指向外部 runtime JSON 快照文件的路径。当此文件存在时：
# - source_context 优先读取外部 runtime 快照中的连接状态
# - global_runtime.facts 优先读取外部 runtime 快照中的事实
# - product_family_status.*.facts 优先读取外部产品族事实
# - 响应 snapshot_id 绑定 state + runtime 快照，防止 GUI 混屏
#
# Path to external runtime JSON snapshot file. When this file exists:
# - source_context preferentially reads connection states from external snapshot
# - global_runtime.facts reads normalized facts from external snapshot
# - product_family_status.*.facts reads product family facts from external snapshot
# - Response snapshot_id binds state + runtime snapshot to prevent GUI desync
#
# 留空则使用内置默认值（适合本地开发 / 演示）
# Leave empty to use built-in defaults (suitable for local dev / demo)
OPENCLAW_RUNTIME_SNAPSHOT_FILE=

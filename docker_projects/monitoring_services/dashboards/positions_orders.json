{
  "uid": "openclaw-positions-orders",
  "title": "4. Positions & Orders / 持仓与订单",
  "description": "Live/paper positions, order flow, execution history",
  "tags": ["openclaw", "positions", "orders"],
  "timezone": "browser",
  "editable": true,
  "refresh": "30s",
  "time": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Open Positions / 当前持仓",
      "type": "table",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "postgres", "uid": "" },
      "targets": [{
        "rawSql": "SELECT DISTINCT ON (symbol, side) symbol, side, size, entry_price, mark_price, unrealized_pnl, leverage, position_value, category, ts FROM position_snapshots ORDER BY symbol, side, ts DESC;",
        "format": "table",
        "refId": "A"
      }],
      "fieldConfig": {
        "overrides": [
          { "matcher": { "id": "byName", "options": "side" }, "properties": [{ "id": "mappings", "value": [{ "type": "value", "options": { "Buy": { "color": "green", "text": "LONG" }, "Sell": { "color": "red", "text": "SHORT" } } }] }] },
          { "matcher": { "id": "byName", "options": "unrealized_pnl" }, "properties": [{ "id": "unit", "value": "currencyUSD" }] },
          { "matcher": { "id": "byName", "options": "position_value" }, "properties": [{ "id": "unit", "value": "currencyUSD" }] }
        ]
      }
    },
    {
      "id": 2,
      "title": "Position Count Over Time / 持仓数量趋势",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "postgres", "uid": "" },
      "targets": [{
        "rawSql": "SELECT ts AS time, COUNT(DISTINCT symbol) AS position_count FROM position_snapshots WHERE $__timeFilter(ts) GROUP BY ts ORDER BY ts;",
        "format": "time_series",
        "refId": "A"
      }]
    },
    {
      "id": 3,
      "title": "Total Unrealized PnL / 总未实现损益",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "postgres", "uid": "" },
      "targets": [{
        "rawSql": "SELECT ts AS time, SUM(unrealized_pnl) AS total_unrealized FROM position_snapshots WHERE $__timeFilter(ts) GROUP BY ts ORDER BY ts;",
        "format": "time_series",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "custom": { "fillOpacity": 15 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 0 }
            ]
          },
          "color": { "mode": "continuous-GrYlRd" }
        }
      }
    },
    {
      "id": 4,
      "title": "Recent Orders / 最近订单",
      "type": "table",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 16 },
      "datasource": { "type": "postgres", "uid": "" },
      "targets": [{
        "rawSql": "SELECT ts, order_id, symbol, side, order_type, qty, price, status, filled_qty, avg_price, fee, CASE WHEN is_paper THEN 'Paper' ELSE 'Live' END AS mode FROM order_events WHERE $__timeFilter(ts) ORDER BY ts DESC LIMIT 100;",
        "format": "table",
        "refId": "A"
      }],
      "fieldConfig": {
        "overrides": [
          { "matcher": { "id": "byName", "options": "side" }, "properties": [{ "id": "mappings", "value": [{ "type": "value", "options": { "Buy": { "color": "green" }, "Sell": { "color": "red" } } }] }] },
          { "matcher": { "id": "byName", "options": "status" }, "properties": [{ "id": "mappings", "value": [{ "type": "value", "options": { "Filled": { "color": "green" }, "Cancelled": { "color": "orange" }, "Rejected": { "color": "red" }, "New": { "color": "blue" } } }] }] }
        ]
      }
    },
    {
      "id": 5,
      "title": "Order Type Distribution / 订单类型分布",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 26 },
      "datasource": { "type": "postgres", "uid": "" },
      "targets": [{
        "rawSql": "SELECT order_type, COUNT(*) AS count FROM order_events WHERE $__timeFilter(ts) GROUP BY order_type;",
        "format": "table",
        "refId": "A"
      }]
    },
    {
      "id": 6,
      "title": "Order Status Distribution / 订单状态分布",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 26 },
      "datasource": { "type": "postgres", "uid": "" },
      "targets": [{
        "rawSql": "SELECT status, COUNT(*) AS count FROM order_events WHERE $__timeFilter(ts) GROUP BY status;",
        "format": "table",
        "refId": "A"
      }]
    },
    {
      "id": 7,
      "title": "Fees Paid / 已付手续费",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 26 },
      "datasource": { "type": "postgres", "uid": "" },
      "targets": [{
        "rawSql": "SELECT date_trunc('hour', ts) AS time, SUM(fee) AS hourly_fees FROM trade_executions WHERE $__timeFilter(ts) GROUP BY 1 ORDER BY 1;",
        "format": "time_series",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": { "unit": "currencyUSD" }
      }
    }
  ],
  "schemaVersion": 39,
  "version": 1
}

#!/usr/bin/env bash
# pre-commit — deterministic repo-native hygiene gate + optional gitleaks
#
# MODULE_NOTE
# 模塊用途：commit 前先無條件掃完整 staged tree，攔截 database artifact /
#   magic、private key、credential DSN、provider/JWT shaped secret；再以
#   gitleaks 補掃 staged diff。canonical 版本存在版控的
#   helper_scripts/git_hooks/pre-commit，由 install_git_hooks.sh 複製進
#   .git/hooks/pre-commit（.git/hooks/ 本身不入版控）。
# 主要邏輯：
#   1. repo-native stdlib gate 恆跑 `--staged`；finding=1 / operational error=2。
#   2. native gate 綠後，gitleaks 在 PATH 才補跑 `protect --staged --redact`。
#   3. gitleaks 不在 PATH → 明示 WARN，但不得跳過 repo-native gate。
# 依賴：git + Python 3 標準庫；gitleaks 是可選補強。
# 硬邊界：
#   - git/repo/Python/native gate 任一不可用都 exit 2；不能把缺工具當 PASS。
#   - gitleaks 缺席只影響第二層補掃，不影響 repo-native deterministic gate。
#   - 不在此 hook 內安裝 / 更新 gitleaks（交由 operator 手動）。
#   - config 走版控的 helper_scripts/git_hooks/.gitleaks.toml（含 test fixture allowlist）。

set -euo pipefail

# ----- 定位 repo 與 config（不硬編碼路徑，符合跨平台規範）-----
# git rev-parse --show-toplevel：取 repo root；hook 在 .git/hooks/ 內被 git 觸發，
# 此時 cwd 已是 repo root，但顯式解析更穩健（worktree / submodule 場景）。
REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || true)"
GITLEAKS_CONFIG=""
if [[ -n "$REPO_ROOT" && -f "$REPO_ROOT/helper_scripts/git_hooks/.gitleaks.toml" ]]; then
    GITLEAKS_CONFIG="$REPO_ROOT/helper_scripts/git_hooks/.gitleaks.toml"
fi

# ----- repo-native gate 恆跑；不可用/執行錯誤 fail closed -----
if [[ -z "$REPO_ROOT" ]] || ! command -v python3 >/dev/null 2>&1; then
    echo "[pre-commit][FAIL] repo-native public repository hygiene gate failed closed。" >&2
    exit 2
fi

echo "[pre-commit] repo-native public repository hygiene gate 掃描完整 staged tree..." >&2
set +e
python3 "$REPO_ROOT/helper_scripts/maintenance_scripts/public_repo_security_gate.py" --repo-root "$REPO_ROOT" --staged
NATIVE_GATE_RC=$?
set -e
if [[ $NATIVE_GATE_RC -ne 0 ]]; then
    echo "[pre-commit][FAIL] repo-native public repository hygiene gate failed closed。" >&2
    exit "$NATIVE_GATE_RC"
fi
echo "[pre-commit][OK] repo-native public repository hygiene gate 通過。" >&2

echo "[pre-commit] applied migration checksum guard 掃描 staged diff..." >&2
python3 "$REPO_ROOT/helper_scripts/db/check_applied_migration_checksums.py" --staged

# ----- gitleaks 是 native gate 後的可選補強 -----
if ! command -v gitleaks >/dev/null 2>&1; then
    echo "[pre-commit][WARN] gitleaks 未安裝；第二層補掃 SKIPPED（repo-native gate 已通過）。" >&2
    echo "[pre-commit][WARN] 安裝方式：brew install gitleaks  或  https://github.com/gitleaks/gitleaks" >&2
    echo "[pre-commit][WARN] 安裝後此 hook 會自動對 staged diff 做 secret 掃描。" >&2
    exit 0
fi

# ----- gitleaks 在 PATH → 掃 staged diff，有 finding 即擋 commit -----
# protect --staged：只掃 staged（git index）內容，不掃整個歷史；快、貼合 pre-commit 語意。
# --redact：finding 輸出遮蔽實際 secret 值，避免敏感資訊被印進終端 / CI log。
GITLEAKS_ARGS=(protect --staged --redact)
if [[ -n "$GITLEAKS_CONFIG" ]]; then
    GITLEAKS_ARGS+=(--config "$GITLEAKS_CONFIG")
fi

echo "[pre-commit] gitleaks 掃描 staged diff..." >&2
# 暫關 errexit 以擷取 gitleaks 退出碼（0=乾淨 / 非 0=發現 finding 或執行錯誤）。
set +e
gitleaks "${GITLEAKS_ARGS[@]}"
GITLEAKS_RC=$?
set -e

if [[ $GITLEAKS_RC -ne 0 ]]; then
    echo "[pre-commit][FAIL] gitleaks 偵測到潛在 secret（退出碼 $GITLEAKS_RC）；commit 已擋下。" >&2
    echo "[pre-commit][FAIL] 修正：移除敏感資訊；若為已知 test fixture 假陽性，請在" >&2
    echo "[pre-commit][FAIL]   helper_scripts/git_hooks/.gitleaks.toml 的 [[rules.allowlist]] / [allowlist] 加 entry。" >&2
    echo "[pre-commit][FAIL] 確認非真 secret 後若需強制提交：git commit --no-verify（請審慎）。" >&2
    exit 1
fi

echo "[pre-commit][OK] gitleaks 掃描通過（無 secret finding）。" >&2
exit 0
